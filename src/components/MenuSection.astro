---
interface MenuItem {
  name: string;
  price: string;
  description?: string; // The '?' means description is optional
}

// 2. Tell Astro that 'menuData' is an array of MenuItems
interface Props {
  menuData: MenuItem[];
}

const { menuData } = Astro.props;
---

<section class="menu-section">
  <h2>Our Menu</h2>
  <div class="menu-grid">
    {menuData.map((item) => (
      <div class="menu-item">
        <div class="item-header">
          <span class="item-name">{item.name}</span>
          <span class="item-price">{item.price}</span>
        </div>
        {item.description && <p class="item-desc">{item.description}</p>}
      </div>
    ))}
  </div>
</section>

<style>
  .menu-section {
    padding: 3rem 1rem;
    max-width: 800px;
    margin: 0 auto;
  }
  h2 {
    text-align: center;
    border-bottom: 2px solid var(--brand-color);
    display: inline-block;
    margin-bottom: 2rem;
  }
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
  .item-header {
    display: flex;
    justify-content: space-between;
    font-weight: bold;
    border-bottom: 1px dashed #ccc;
    padding-bottom: 5px;
  }
  .item-price {
    color: var(--brand-color);
  }
  .item-desc {
    font-size: 0.9rem;
    color: #666;
    margin-top: 5px;
  }
</style>