---
import settings from '../settings.json';

// We pull the branding details to use in the CSS and Meta tags
const { restaurantName, themeColor } = settings;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{restaurantName}</title>

		<!-- 1. The Netlify Identity Widget (Required for the login popup) -->
		<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

		<style define:vars={{ brandColor: themeColor }}>
			:root {
				--brand-color: var(--brandColor);
			}
			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
				font-family: system-ui, -apple-system, sans-serif;
			}
			nav {
				background: #fff;
				padding: 1rem;
				border-bottom: 1px solid #eee;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.logo {
				font-weight: bold;
				color: var(--brand-color);
				font-size: 1.2rem;
			}
			footer {
				text-align: center;
				padding: 2rem;
				font-size: 0.8rem;
				color: #888;
			}
		</style>
	</head>
	<body>
		<nav>
			<div class="logo">{restaurantName}</div>
		</nav>

		<slot />

		<footer>
			&copy; {new Date().getFullYear()} {restaurantName}. Built for local business.
		</footer>

    <script is:inline>
      // This listener waits for the Netlify script to be fully loaded and ready
      document.addEventListener('DOMContentLoaded', () => {
        if (window.netlifyIdentity) {
          // 1. Initialize the widget
          window.netlifyIdentity.on("init", (user) => {
            // 2. Handle redirection after login
            if (user) {
              // If we are on the home page and logged in, go to admin
              if (window.location.pathname === "/") {
                document.location.href = "/admin/";
              }
            } else {
              // 3. Force the popup if there is a token in the URL
              const hash = window.location.hash;
              if (hash && (hash.includes("invite_token") || hash.includes("recovery_token"))) {
                window.netlifyIdentity.open();
              }
            }
          });

          // 4. Global login event listener
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    </script>
	</body>
</html>