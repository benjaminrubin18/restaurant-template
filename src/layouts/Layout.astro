---
import settings from '../settings.json';
---

<!doctype html>
<html>
  <head>
    <title>{settings.restaurantName}</title>
    <style define:vars={{ brandColor: settings.themeColor }}>
      :root { --primary: var(--brandColor); }
      body { font-family: sans-serif; }
      h1 { color: var(--primary); }
    </style>
  </head>
  <body>
    <nav> <strong>{settings.restaurantName}</strong> </nav>
    
    <slot /> <!-- Your index.astro content appears here! -->

    <footer>© 2026 {settings.restaurantName}</footer>
  </body>
</html>


<style define:vars={{ primaryColor: settings.themeColor }}>
  :root {
    --brand-color: var(--primaryColor);
  }

  /* Now you can use it anywhere in your CSS! */
  h1 {
    color: var(--brand-color);
  }
  
  .btn-order {
    background-color: var(--brand-color);
    border: 2px solid var(--brand-color);
  }
</style>
