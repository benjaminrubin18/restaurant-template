---
import settings from '../settings.json';

// We pull the branding details to use in the CSS and Meta tags
const { restaurantName, themeColor } = settings;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{restaurantName}</title>

		<!-- 1. The Netlify Identity Widget (Required for the login popup) -->
		<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

		<style define:vars={{ brandColor: themeColor }}>
			:root {
				--brand-color: var(--brandColor);
			}
			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
				font-family: system-ui, -apple-system, sans-serif;
			}
			nav {
				background: #fff;
				padding: 1rem;
				border-bottom: 1px solid #eee;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.logo {
				font-weight: bold;
				color: var(--brand-color);
				font-size: 1.2rem;
			}
			footer {
				text-align: center;
				padding: 2rem;
				font-size: 0.8rem;
				color: #888;
			}
		</style>
	</head>
	<body>
		<nav>
			<div class="logo">{restaurantName}</div>
		</nav>

		<slot />

		<footer>
			&copy; {new Date().getFullYear()} {restaurantName}. Built for local business.
		</footer>

		<!-- 2. The Redirection Script -->
		<!-- This tells the browser: "If the user logs in, send them to /admin" -->
		<script is:inline>
			if (window.netlifyIdentity) {
				window.netlifyIdentity.on("init", (user) => {
					if (!user) {
						window.netlifyIdentity.on("login", () => {
							document.location.href = "/admin/";
						});
					}
				});
			}
		</script>
	</body>
</html>